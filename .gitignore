# ---- Build artifacts ----
build/
cmake-build-*/
out/

# ---- Project-local isolated build and install trees ----
/.build/
/.deps/
/build-*/

# ---- CMake generated (in case build/ is not used) ----
CMakeCache.txt
CMakeFiles/
cmake_install.cmake
Makefile
install_manifest.txt
compile_commands.json

# ---- Qt / IDE / Editor ----
*.user
*.user.*
*.pro.user
*.autosave
.vscode/
.idea/
*.swp
*~
.*.un~
*.orig

# ---- OS ----
.DS_Store
Thumbs.db

# ---- macOS generated bundles and debug symbols ----
*.app/
*.dSYM/

# ---- Logs & temp ----
*.log
/tmp/
qt_stderr*.log

# ---- Metavision raw file index cache ----
*.tmp_index

# ---- User-private launcher (local env customisation) ----
run.local.sh

# ---- Python (for future tooling) ----
__pycache__/
*.py[cod]
*.egg-info/
.venv/

# ---- Reference materials (third-party repos, not committed) ----
ref/

# ---- Pretrained models (large binaries, not committed) ----
# The conversion script (models/convert_to_onnx.py) IS committed; the
# downloaded .pth.tar and the exported .onnx / .onnx.data are not —
# users regenerate them locally following doc/design.md §4.4.2.
models/*.pth.tar
models/*.pth
models/*.onnx
models/*.onnx.data
models/*.bin

# ---- Third-party prebuilt libraries (not committed) ----
# ONNX Runtime C++ prebuilt package (CPU). Users download and extract it
# to third_party/onnxruntime/ following doc/design.md §4.4.2. Only the
# directory contents are ignored; the directory itself is kept via .gitkeep.
third_party/onnxruntime/
